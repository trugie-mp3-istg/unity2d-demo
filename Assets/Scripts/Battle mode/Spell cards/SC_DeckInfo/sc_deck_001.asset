  scName: Snowball
  scSprite: {fileID: -3527768119634048410, guid: 86efb9b5734c0974bafd1a4c9b532df0, type: 3}
  scPrefab: {fileID: 1472827515587832694, guid: f46667356a765014ba464e530e00e9fa, type: 3}
