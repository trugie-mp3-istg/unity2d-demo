  scID: 3
  scName: Icicle Machine Gun
  scSprite: {fileID: -3957686416127495256, guid: def2a3b6df45bd24a83d3748a6253038, type: 3}
  scPrefab: {fileID: 2342242235373487406, guid: 398346bc41aac24458578ba08238d6fd, type: 3}
